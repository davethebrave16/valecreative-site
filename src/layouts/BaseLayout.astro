---
import '../styles/global.css'

interface Props {
	title: string
	description?: string
}

const { title, description = 'Vale Creative — the portfolio of Valentina Damiano' } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title} — Vale Creative</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>
	<body>
		<header>
			<div class="container">
				<nav>
					<a href="/">Home</a>
					<a href="/works">Works</a>
					<a href="/series">Series</a>
					<a href="/techniques">Techniques</a>
					<a href="/about">About</a>
					<a href="/commissions">Commissions</a>
					<a href="/contact">Contact</a>
				</nav>
			</div>
		</header>

		<main>
			<div class="container">
				<slot />
			</div>
		</main>

		<footer>
			<div class="container">
				<p>© {new Date().getFullYear()} Valentina Damiano — Vale Creative</p>
			</div>
		</footer>
	</body>
</html>
