---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommissionRequestForm from '@/components/CommissionRequestForm'
import { useTranslations } from '@/i18n/utils'

const locale = 'en'
const t = useTranslations(locale)
---

<BaseLayout title="Commissions — Request a bespoke artwork" lang={locale} description={t.meta.commissionsDescription}>
	<section class="vd-rise" style="padding:clamp(34px,5vw,64px) 0 clamp(50px,6vw,90px)">
		<div class="container">
			<div style="position:relative">
				<span style="position:absolute;left:-26px;top:-18px;width:70px;height:70px;border-radius:50%;background:conic-gradient(from 180deg,var(--rose),var(--syellow),var(--sblue),var(--rose));filter:blur(20px);opacity:.3;pointer-events:none"></span>
				<div class="vd-eyebrow">{t.commissions.eyebrow}</div>
				<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(34px,5.5vw,62px);margin:10px 0 0;color:var(--ink)">{t.commissions.title}</h1>
				<p style="max-width:52ch;margin:14px 0 28px;font-size:16.5px;line-height:1.7;color:#52564c">{t.commissions.subtitle}</p>
				<div style="display:flex;flex-direction:column;border-top:1px solid var(--line);max-width:460px;margin-bottom:40px">
					<div style="display:flex;justify-content:space-between;gap:14px;padding:13px 0;border-bottom:1px solid var(--line)">
						<span style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)">{t.commissions.contactLabels.email}</span>
						<span style="font-size:15px;color:var(--ink)">{t.commissions.contactValues.email}</span>
					</div>
					<div style="display:flex;justify-content:space-between;gap:14px;padding:13px 0;border-bottom:1px solid var(--line)">
						<span style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)">{t.commissions.contactLabels.atelier}</span>
						<span style="font-size:15px;color:var(--ink)">{t.commissions.contactValues.atelier}</span>
					</div>
					<div style="display:flex;justify-content:space-between;gap:14px;padding:13px 0;border-bottom:1px solid var(--line)">
						<span style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)">{t.commissions.contactLabels.instagram}</span>
						<span style="font-size:15px;color:var(--ink)">{t.commissions.contactValues.instagram}</span>
					</div>
				</div>
			</div>
			<CommissionRequestForm client:visible labels={t.commissions} />
		</div>
	</section>
</BaseLayout>
