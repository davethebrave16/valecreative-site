---
import BaseLayout from '@/layouts/BaseLayout.astro'
import WorksGrid from '@/components/WorksGrid'
import { getArtworks, getPublishedSeries, getTechniques } from '@/lib/fetchContent'
import { useTranslations } from '@/i18n/utils'

const locale = 'en'
const t = useTranslations(locale)

const [artworks, series, techniques] = await Promise.all([
	getArtworks(),
	getPublishedSeries(),
	getTechniques(),
])

const seriesById = Object.fromEntries(series.map((s) => [s.id, s.name]))
const techniqueById = Object.fromEntries(techniques.map((t) => [t.id, t.name]))

const workItems = artworks.map((a) => ({
	id: a.id,
	title: a.title,
	slug: a.slug,
	year: a.year,
	availability: a.availability,
	origin: a.origin,
	dimensions: a.dimensions,
	coverImage: a.coverImage,
	seriesName: a.seriesId ? seriesById[a.seriesId] : undefined,
	techniqueName: a.techniqueId ? techniqueById[a.techniqueId] : undefined,
}))

const seriesNames = series.map((s) => s.name)
---

<BaseLayout title={t.works.title} lang={locale}>
	<section class="vd-rise" style="padding:clamp(34px,5vw,64px) 0 clamp(50px,6vw,90px)">
		<div class="container">
			<div class="vd-eyebrow">{t.works.eyebrow}</div>
			<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(34px,5.5vw,62px);margin:10px 0 0;color:var(--ink)">{t.works.title}</h1>
			<p style="max-width:58ch;margin:14px 0 0;font-size:16px;line-height:1.65;color:#52564c">{t.works.subtitle}</p>

			{artworks.length === 0 ? (
				<p style="color:var(--muted);margin-top:2rem">{t.works.empty}</p>
			) : (
				<WorksGrid
					client:visible
					artworks={workItems}
					seriesNames={seriesNames}
					labels={{
						filterAll: t.works.filterAll,
						filterPersonal: t.works.filterPersonal,
						filterCommissioned: t.works.filterCommissioned,
						countSuffix: t.works.countSuffix,
						legendAvailable: t.works.legendAvailable,
						legendRequest: t.works.legendRequest,
						legendSold: t.works.legendSold,
						availability: t.works.availability,
						orientation: t.works.orientation,
					}}
				/>
			)}
		</div>
	</section>
</BaseLayout>
