---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getArtworks, getPublishedSeries, getContentBySlug } from '@/lib/fetchContent'
import { useTranslations } from '@/i18n/utils'

const locale = Astro.currentLocale ?? 'it'
const t = useTranslations(locale)

const [allArtworks, series, hero] = await Promise.all([
	getArtworks(),
	getPublishedSeries(),
	getContentBySlug('homepage_hero'),
])

const featuredArtworks = allArtworks.filter((a) => a.featured).slice(0, 5)
const heroArtwork = allArtworks.find((a) => a.isHero) ?? featuredArtworks[0]

// Count artworks per series for the series teaser
const artworkCountBySeries: Record<string, number> = {}
for (const a of allArtworks) {
	if (a.seriesId) artworkCountBySeries[a.seriesId] = (artworkCountBySeries[a.seriesId] ?? 0) + 1
}

function getOrientation(dims?: { width?: number; height?: number }) {
	if (!dims?.width || !dims?.height) return 'square'
	const r = dims.width / dims.height
	if (r < 0.85) return 'portrait'
	if (r > 1.2) return 'landscape'
	return 'square'
}

function cellGridStyle(orient: string) {
	if (orient === 'portrait') return 'grid-row:span 3'
	if (orient === 'landscape') return 'grid-row:span 2;grid-column:span 2'
	return 'grid-row:span 2'
}

const heroTitle = hero?.title ?? t.home.heroTitle
const heroBody = hero?.body
---

<BaseLayout title="Home" description={`Vale Creative — ${t.home.heroSubtitle}`}>

	<!-- ── Hero ── -->
	<section style="position:relative;overflow:hidden">
		<div style="position:absolute;inset:0;background:radial-gradient(130% 90% at 78% 8%,rgba(216,185,106,.42),rgba(239,231,214,0) 46%),radial-gradient(120% 100% at 8% 100%,rgba(46,64,58,.34),rgba(239,231,214,0) 50%);pointer-events:none"></div>
		<div class="container" style="padding-block:clamp(40px,6vw,92px) clamp(34px,4vw,64px);position:relative">
			<div class="vd-hero">
				<div class="vd-rise">
					<div style="display:flex;align-items:center;gap:12px;margin-bottom:22px">
						<span style="width:30px;height:1px;background:var(--gold)"></span>
						<span style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--bark)">{t.home.eyebrow}</span>
					</div>
					{heroBody ? (
						<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(44px,8vw,94px);line-height:.95;letter-spacing:-.01em;margin:0;color:var(--ink)" set:html={heroBody} />
					) : (
						<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(44px,8vw,94px);line-height:.95;letter-spacing:-.01em;margin:0;color:var(--ink)">
							{heroTitle}
						</h1>
					)}
					<p style="max-width:46ch;margin:26px 0 0;font-size:clamp(16px,1.6vw,18.5px);line-height:1.7;color:#41463d">{t.home.heroSubtitle}</p>
					<div style="display:flex;flex-wrap:wrap;gap:14px;margin-top:34px">
						<a href="/works" class="vd-btn-primary">{t.home.ctaWorks} <span>→</span></a>
						<a href="/commissions" class="vd-btn-outline">{t.home.ctaCommission}</a>
					</div>
				</div>

				<!-- Hero image: first featured artwork or gradient placeholder -->
				<div class="vd-rise" style="position:relative">
					<div style="position:relative;aspect-ratio:4/5;border-radius:4px;overflow:hidden;border:1px solid var(--line);box-shadow:0 30px 70px -36px rgba(31,42,34,.6)">
						{heroArtwork?.coverImage?.medium || heroArtwork?.coverImage?.original ? (
							<img
								src={heroArtwork.coverImage!.medium ?? heroArtwork.coverImage!.original}
								alt={heroArtwork.coverImage!.alt ?? heroArtwork.title}
								width={heroArtwork.coverImage!.width}
								height={heroArtwork.coverImage!.height}
								loading="eager"
								style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover"
							/>
						) : (
							<div style="position:absolute;inset:0;background:radial-gradient(130% 120% at 30% 14%,#d9b25e 0%,#6b4f37 44%,#243029 100%)"></div>
						)}
						<div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0) 55%,rgba(20,28,22,.55))"></div>
						{heroArtwork && (
							<div style="position:absolute;left:18px;right:18px;bottom:16px;color:#fff">
								<div style="font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:600">{heroArtwork.title}</div>
								<div style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.1em;opacity:.85;margin-top:3px">{heroArtwork.year}</div>
							</div>
						)}
					</div>
					<div style="position:absolute;left:-18px;bottom:-18px;width:96px;height:96px;border-radius:50%;background:conic-gradient(from 200deg,var(--rose),var(--syellow),var(--sblue),var(--rose));filter:blur(26px);opacity:.32;z-index:-1"></div>
				</div>
			</div>
		</div>
	</section>

	<!-- ── Ornamental divider ── -->
	<div class="container">
		<div class="vd-divider" style="padding:clamp(34px,5vw,58px) 0 clamp(20px,2vw,28px)">
			<span class="vd-divider-line"></span>
			<span class="vd-divider-diamond"></span>
			<span class="vd-divider-line"></span>
		</div>
	</div>

	<!-- ── Featured works ── -->
	{featuredArtworks.length > 0 && (
		<section style="padding-bottom:clamp(30px,4vw,56px)">
			<div class="container">
				<div style="display:flex;align-items:flex-end;justify-content:space-between;gap:18px;margin-bottom:26px">
					<div>
						<div class="vd-eyebrow">{t.home.featuredEyebrow}</div>
						<h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(28px,4vw,44px);margin:8px 0 0;color:var(--ink)">{t.home.featuredTitle}</h2>
					</div>
					<a href="/works" style="font-weight:600;font-size:14px;color:var(--verde);white-space:nowrap;transition:color .2s" onmouseover="this.style.color='var(--verde-deep)'" onmouseout="this.style.color='var(--verde)'">{t.home.featuredLink}</a>
				</div>
				<div class="vd-grid">
					{featuredArtworks.map((artwork) => {
						const orient = getOrientation(artwork.dimensions)
						const imgSrc = artwork.coverImage?.thumb ?? artwork.coverImage?.medium ?? artwork.coverImage?.original
						return (
							<a
								href={`/works/${artwork.slug}`}
								class="vd-cell"
								style={cellGridStyle(orient)}
							>
								{imgSrc ? (
									<img
										src={imgSrc}
										alt={artwork.coverImage?.alt ?? artwork.title}
										loading="lazy"
										class="vd-img"
										style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover"
									/>
								) : (
									<div class="vd-img" style={`position:absolute;inset:0;background:radial-gradient(130% 120% at 30% 14%,#d9b25e 0%,#6b4f37 44%,#243029 100%)`}></div>
								)}
								<span style="position:absolute;left:11px;top:9px;font-family:'Spline Sans Mono',monospace;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.82);z-index:2">{orient === 'portrait' ? '[ ritratto ]' : orient === 'landscape' ? '[ paesaggio ]' : '[ quadrato ]'}</span>
								<div class="vd-cap" style="position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:14px;background:linear-gradient(180deg,rgba(0,0,0,0) 45%,rgba(18,26,20,.74));z-index:2">
									<div style="font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#fff;line-height:1.05">{artwork.title}</div>
									<div style="font-family:'Spline Sans Mono',monospace;font-size:10px;letter-spacing:.08em;color:rgba(255,255,255,.82);margin-top:4px">{artwork.year}</div>
								</div>
							</a>
						)
					})}
				</div>
			</div>
		</section>
	)}

	<!-- ── Intro band ── -->
	<section style="background:var(--forest);color:#ece4d2">
		<div class="container" style="padding-block:clamp(46px,6vw,84px)">
			<div class="vd-two">
				<div>
					<div style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.26em;text-transform:uppercase;color:var(--gold-soft)">{t.home.bandEyebrow}</div>
					<img src="/logo.svg" alt="" width="120" height="120" style="border-radius:50%;margin-top:26px;opacity:.96" />
				</div>
				<div>
					<p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(24px,3.2vw,38px);line-height:1.32;margin:0;color:#f3ecdc">{t.home.bandQuote}</p>
					<p style="max-width:58ch;margin:24px 0 0;font-size:16.5px;line-height:1.75;color:#cfc8b6">{t.home.bandText}</p>
					<a href="/about" style="display:inline-flex;align-items:center;gap:9px;margin-top:28px;font-weight:600;font-size:15px;color:var(--gold-soft);transition:color .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--gold-soft)'">{t.home.bandLink}</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ── Series teaser ── -->
	{series.length > 0 && (
		<section>
			<div class="container" style="padding-block:clamp(46px,6vw,80px)">
				<div style="display:flex;align-items:flex-end;justify-content:space-between;gap:18px;margin-bottom:26px">
					<h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(28px,4vw,44px);margin:0;color:var(--ink)">{t.home.seriesTitle}</h2>
					<a href="/series" style="font-weight:600;font-size:14px;color:var(--verde);transition:color .2s" onmouseover="this.style.color='var(--verde-deep)'" onmouseout="this.style.color='var(--verde)'">{t.home.seriesLink}</a>
				</div>
				<div class="vd-cards">
					{series.map((s) => {
						const count = artworkCountBySeries[s.id] ?? 0
						const imgSrc = s.coverImage?.thumb ?? s.coverImage?.medium ?? s.coverImage?.original
						return (
							<a
								href={`/series/${s.slug}`}
								style="text-align:left;border:1px solid var(--line);background:var(--parchment);border-radius:5px;overflow:hidden;display:block;text-decoration:none;transition:border-color .25s"
								onmouseover="this.style.borderColor='var(--gold)'"
								onmouseout="this.style.borderColor='var(--line)'"
							>
								{imgSrc ? (
									<img src={imgSrc} alt={s.coverImage?.alt ?? s.name} loading="lazy" style="width:100%;height:150px;object-fit:cover" />
								) : (
									<div style="height:150px;background:linear-gradient(155deg,#33473b 0%,#5d6b4d 40%,#b68a3c 100%)"></div>
								)}
								<div style="padding:18px 18px 20px">
									<div style="font-family:'Spline Sans Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--bark)">{t.home.seriesCount(count)}</div>
									<div style="font-family:'Cormorant Garamond',serif;font-size:25px;font-weight:600;color:var(--ink);margin-top:6px">{s.name}</div>
									{s.description && <p style="font-size:14px;line-height:1.6;color:#52564c;margin:8px 0 0">{s.description}</p>}
								</div>
							</a>
						)
					})}
				</div>
			</div>
		</section>
	)}

</BaseLayout>
