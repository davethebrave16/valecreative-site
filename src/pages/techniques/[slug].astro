---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getTechniques, getArtworks } from '@/lib/fetchContent'
import { useTranslations } from '@/i18n/utils'
import type { Technique } from '@/lib/types'

export async function getStaticPaths() {
	const techniques = await getTechniques()
	return techniques.map((t) => ({
		params: { slug: t.slug },
		props: { technique: t },
	}))
}

interface Props {
	technique: Technique
}

const locale = Astro.currentLocale ?? 'it'
const t = useTranslations(locale)

const { technique } = Astro.props
const allArtworks = await getArtworks()
const artworks = allArtworks.filter((a) => a.techniqueId === technique.id)

function getOrientation(dims?: { width?: number; height?: number }) {
	if (!dims?.width || !dims?.height) return 'square'
	const r = dims.width / dims.height
	if (r < 0.85) return 'portrait'
	if (r > 1.2) return 'landscape'
	return 'square'
}

function cellGridStyle(orient: string) {
	if (orient === 'portrait') return 'grid-row:span 3'
	if (orient === 'landscape') return 'grid-row:span 2;grid-column:span 2'
	return 'grid-row:span 2'
}
---

<BaseLayout title={technique.name} description={technique.description}>
	<section class="vd-rise" style="padding:clamp(34px,5vw,64px) 0 clamp(50px,6vw,90px)">
		<div class="container">
			<a href="/techniques" style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);display:inline-block;margin-bottom:24px;transition:color .2s" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--muted)'">{t.techniques.backLink}</a>

			<div class="vd-eyebrow">{t.techniques.category[technique.category] ?? technique.category}</div>
			<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(34px,5.5vw,62px);margin:10px 0 0;color:var(--ink)">{technique.name}</h1>

			{technique.description && (
				<p style="max-width:62ch;margin:16px 0 0;font-size:16.5px;line-height:1.75;color:#41463d">{technique.description}</p>
			)}

			{artworks.length > 0 && (
				<section style="margin-top:clamp(36px,4vw,56px)">
					<div class="vd-divider" style="margin-bottom:clamp(24px,3vw,36px)">
						<span class="vd-divider-line"></span>
						<span class="vd-divider-diamond"></span>
						<span class="vd-divider-line"></span>
					</div>
					<h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(24px,3vw,34px);margin:0 0 24px;color:var(--ink)">{t.techniques.relatedWorks}</h2>
					<div class="vd-grid">
						{artworks.map((artwork) => {
							const orient = getOrientation(artwork.dimensions)
							const imgSrc = artwork.coverImage?.thumb ?? artwork.coverImage?.medium ?? artwork.coverImage?.original
							return (
								<a href={`/works/${artwork.slug}`} class="vd-cell" style={cellGridStyle(orient)}>
									{imgSrc ? (
										<img src={imgSrc} alt={artwork.coverImage?.alt ?? artwork.title} loading="lazy" class="vd-img" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" />
									) : (
										<div class="vd-img" style="position:absolute;inset:0;background:linear-gradient(155deg,#33473b 0%,#5d6b4d 40%,#b68a3c 100%)"></div>
									)}
									<div class="vd-cap" style="position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:14px;background:linear-gradient(180deg,rgba(0,0,0,0) 42%,rgba(18,26,20,.76));z-index:2">
										<div style="font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#fff;line-height:1.05">{artwork.title}</div>
										<div style="font-family:'Spline Sans Mono',monospace;font-size:10px;letter-spacing:.08em;color:rgba(255,255,255,.82);margin-top:4px">{artwork.year}</div>
									</div>
								</a>
							)
						})}
					</div>
				</section>
			)}

			{artworks.length === 0 && (
				<p style="color:var(--muted);margin-top:2rem">{t.techniques.noWorks}</p>
			)}
		</div>
	</section>
</BaseLayout>
