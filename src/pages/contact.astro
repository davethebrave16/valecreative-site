	<article style="max-width: 720px;">
		<h1>Contact</h1>
		<p style="margin-bottom: 2rem; max-width: 65ch;">
			Have a question or just want to say hello? Use the form below.
		</p>

		<ContactForm client:visible />
	</article>
</BaseLayout>
