---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getPublishedSeries, getArtworks, getCategories } from '@/lib/fetchContent'
import { useTranslations } from '@/i18n/utils'
import type { Series } from '@/lib/types'

export async function getStaticPaths() {
	const series = await getPublishedSeries()
	return series.map((s) => ({
		params: { slug: s.slug },
		props: { series: s },
	}))
}

interface Props {
	series: Series
}

const locale = Astro.currentLocale ?? 'it'
const t = useTranslations(locale)

const { series } = Astro.props
const [allArtworks, categories] = await Promise.all([getArtworks(), getCategories()])
const artworks = allArtworks.filter((a) => a.seriesId === series.id)
const categoryById = Object.fromEntries(categories.map(c => [c.id, c.name]))

function getOrientation(dims?: { width?: number; height?: number }) {
	if (!dims?.width || !dims?.height) return 'square'
	const r = dims.width / dims.height
	if (r < 0.85) return 'portrait'
	if (r > 1.2) return 'landscape'
	return 'square'
}

function cellGridStyle(orient: string) {
	if (orient === 'portrait') return 'grid-row:span 3'
	if (orient === 'landscape') return 'grid-row:span 2;grid-column:span 2'
	return 'grid-row:span 2'
}

const heroBg = series.coverImage?.original
	? `url('${series.coverImage.medium ?? series.coverImage.original}') center/cover no-repeat`
	: 'radial-gradient(130% 120% at 30% 14%,#d9b25e 0%,#6b4f37 44%,#243029 100%)'
---

<BaseLayout
	title={series.name}
	description={series.description ?? `Serie ${series.name} — Valentina Damiano`}
	ogImage={series.coverImage?.medium ?? series.coverImage?.original}
	noAlternate={true}
>
	<script slot="head" type="application/ld+json" set:html={JSON.stringify({
		'@context': 'https://schema.org',
		'@graph': [
			{
				'@type': 'CreativeWorkSeries',
				name: series.name,
				...(series.description ? { description: series.description } : {}),
				...(series.coverImage?.original ? { image: series.coverImage.original } : {}),
				creator: { '@type': 'Person', name: 'Valentina Damiano' },
				url: `https://valentinadamiano.it/series/${series.slug}`,
			},
			{
				'@type': 'BreadcrumbList',
				itemListElement: [
					{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://valentinadamiano.it' },
					{ '@type': 'ListItem', position: 2, name: 'Serie', item: 'https://valentinadamiano.it/series' },
					{ '@type': 'ListItem', position: 3, name: series.name },
				],
			},
		],
	})} />

	<section class="vd-rise">
		<!-- Hero banner -->
		<div style={`position:relative;overflow:hidden;background:${heroBg}`}>
			<div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,28,22,.18),rgba(20,28,22,.62))"></div>
			<div class="container" style="position:relative;padding-block:clamp(46px,7vw,110px)">
				<a href="/series" style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.85);display:inline-block;margin-bottom:16px">{t.series.backLink}</a>
				<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(38px,6vw,76px);margin:0;color:#fff">{series.name}</h1>
				{series.description && (
					<p style="max-width:54ch;margin:14px 0 0;font-size:clamp(16px,1.7vw,19px);line-height:1.6;color:#ece5d6">{series.description}</p>
				)}
			</div>
		</div>

		<!-- Artworks grid -->
		<div class="container" style="padding-block:clamp(34px,4vw,56px) clamp(50px,6vw,90px)">
			{artworks.length === 0 ? (
				<p style="color:var(--muted)">{t.series.noWorks}</p>
			) : (
				<div class="vd-grid">
					{artworks.map((artwork) => {
						const orient = getOrientation(artwork.dimensions)
						const imgSrc = artwork.coverImage?.thumb ?? artwork.coverImage?.medium ?? artwork.coverImage?.original
						return (
							<a
								href={`/works/${artwork.slug}`}
								class="vd-cell"
								style={cellGridStyle(orient)}
							>
								{imgSrc ? (
									<img
										src={imgSrc}
										alt={artwork.coverImage?.alt ?? artwork.title}
										loading="lazy"
										class="vd-img"
										style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover"
									/>
								) : (
									<div class="vd-img" style="position:absolute;inset:0;background:radial-gradient(130% 120% at 30% 14%,#d9b25e 0%,#6b4f37 44%,#243029 100%)"></div>
								)}
								{artwork.categoryIds?.[0] && categoryById[artwork.categoryIds[0]] && (
									<span style="position:absolute;left:11px;top:9px;font-family:'Spline Sans Mono',monospace;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.82);z-index:2">[ {categoryById[artwork.categoryIds[0]]} ]</span>
								)}
								<div class="vd-cap" style="position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:14px;background:linear-gradient(180deg,rgba(0,0,0,0) 42%,rgba(18,26,20,.76));z-index:2">
									<div style="font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#fff;line-height:1.05">{artwork.title}</div>
									<div style="font-family:'Spline Sans Mono',monospace;font-size:10px;letter-spacing:.08em;color:rgba(255,255,255,.82);margin-top:4px">{artwork.year}</div>
								</div>
							</a>
						)
					})}
				</div>
			)}
		</div>
	</section>
</BaseLayout>
