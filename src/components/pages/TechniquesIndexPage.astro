---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getTechniques } from '@/lib/fetchContent'
import { useTranslations, getLocalePath } from '@/i18n/utils'

interface Props {
	locale: string
}

const { locale } = Astro.props
const t = useTranslations(locale)
const p = (path: string) => getLocalePath(locale, path)

const techniques = await getTechniques()

const pageTitle = locale === 'it' ? 'Tecniche pittoriche' : 'Painting Techniques'
---

<BaseLayout title={pageTitle} lang={locale} description={t.meta.techniquesDescription}>
	<section class="vd-rise" style="padding:clamp(34px,5vw,64px) 0 clamp(50px,6vw,90px)">
		<div class="container">
			<div class="vd-eyebrow">{t.techniques.eyebrow}</div>
			<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(34px,5.5vw,62px);margin:10px 0 0;color:var(--ink)">{t.techniques.title}</h1>
			<p style="max-width:60ch;margin:14px 0 36px;font-size:16px;line-height:1.65;color:#52564c">{t.techniques.subtitle}</p>

			{techniques.length === 0 ? (
				<p style="color:var(--muted)">{t.techniques.empty}</p>
			) : (
				<div style="display:grid;grid-template-columns:1fr;gap:0;border-top:1px solid var(--line)">
					{techniques.map((tech, i) => (
						<a
							href={p(`/techniques/${tech.slug}`)}
							style="display:grid;grid-template-columns:46px 1fr;gap:clamp(14px,2vw,30px);align-items:start;padding:clamp(20px,2.4vw,30px) 0;border-bottom:1px solid var(--line);text-decoration:none;transition:opacity .2s"
							onmouseover="this.style.opacity='.75'"
							onmouseout="this.style.opacity='1'"
						>
							<span style="font-family:'Spline Sans Mono',monospace;font-size:13px;color:var(--gold);padding-top:6px">{String(i + 1).padStart(2, '0')}</span>
							<div style="display:grid;grid-template-columns:1fr;gap:6px">
								<div style="display:flex;align-items:center;gap:12px">
									<span style="width:9px;height:9px;border:1px solid var(--gold);transform:rotate(45deg);flex:none"></span>
									<h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(22px,2.6vw,30px);margin:0;color:var(--ink)">{tech.name}</h3>
								</div>
								<div style="display:flex;align-items:center;gap:10px">
									<span style="font-family:'Spline Sans Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--bark)">{t.techniques.category[tech.category] ?? tech.category}</span>
								</div>
								{tech.description && (
									<p style="max-width:64ch;margin:4px 0 0;font-size:15.5px;line-height:1.7;color:#52564c">{tech.description}</p>
								)}
							</div>
						</a>
					))}
				</div>
			)}
		</div>
	</section>
</BaseLayout>
