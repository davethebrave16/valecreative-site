---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getArtworkGallery, getPublishedSeries, getTechniques } from '@/lib/fetchContent'
import { useTranslations, getLocalePath } from '@/i18n/utils'
import type { Artwork } from '@/lib/types'

interface Props {
	locale: string
	artwork: Artwork
}

const { locale, artwork } = Astro.props
const t = useTranslations(locale)
const p = (path: string) => getLocalePath(locale, path)
const SITE = 'https://valentinadamiano.it'

const [gallery, series, techniques] = await Promise.all([
	getArtworkGallery(artwork.id),
	getPublishedSeries(),
	getTechniques(),
])

const seriesById = Object.fromEntries(series.map((s) => [s.id, s.name]))
const techniqueById = Object.fromEntries(techniques.map((te) => [te.id, te.name]))

const seriesName = artwork.seriesId ? seriesById[artwork.seriesId] : undefined
const techniqueName = artwork.techniqueId ? techniqueById[artwork.techniqueId] : undefined

const availColor = artwork.availability === 'for_sale'
	? 'var(--verde)'
	: artwork.availability === 'sold'
	? '#9a8d77'
	: '#9a8d77'

const availLabel = t.works.availability[artwork.availability] ?? artwork.availability

const formatDim = (d?: { width?: number; height?: number; unit?: string }) =>
	d?.width && d?.height ? `${d.width} × ${d.height} ${d.unit ?? 'cm'}` : ''

const dimStr = formatDim(artwork.dimensions)
---

<BaseLayout
	title={artwork.title}
	lang={locale}
	description={artwork.description ?? `${artwork.title} · ${artwork.year}${techniqueName ? ` · ${techniqueName}` : ''} — Valentina Damiano`}
	ogImage={artwork.coverImage?.medium ?? artwork.coverImage?.original}
	ogType="article"
>
	<script slot="head" type="application/ld+json" set:html={JSON.stringify({
		'@context': 'https://schema.org',
		'@graph': [
			{
				'@type': 'VisualArtwork',
				name: artwork.title,
				...(artwork.description ? { description: artwork.description } : {}),
				...(artwork.coverImage?.original ? { image: artwork.coverImage.original } : {}),
				dateCreated: String(artwork.year ?? ''),
				creator: { '@type': 'Person', name: 'Valentina Damiano' },
				...(techniqueName ? { artMedium: techniqueName } : {}),
				...(artwork.support ? { artworkSurface: artwork.support } : {}),
				...(artwork.dimensions?.width && artwork.dimensions?.height ? {
					width: `${artwork.dimensions.width} ${artwork.dimensions.unit ?? 'cm'}`,
					height: `${artwork.dimensions.height} ${artwork.dimensions.unit ?? 'cm'}`,
				} : {}),
				...(artwork.availability === 'for_sale' ? {
					offers: {
						'@type': 'Offer',
						availability: 'https://schema.org/InStock',
						priceCurrency: 'EUR',
						seller: { '@type': 'Person', name: 'Valentina Damiano' },
					},
				} : {}),
			},
			{
				'@type': 'BreadcrumbList',
				itemListElement: [
					{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
					{ '@type': 'ListItem', position: 2, name: t.nav.works, item: `${SITE}${p('/works')}` },
					{ '@type': 'ListItem', position: 3, name: artwork.title },
				],
			},
		],
	})} />

	<section class="vd-rise" style="padding:clamp(20px,3vw,40px) 0 clamp(50px,6vw,80px)">
		<div class="container">
			<!-- Breadcrumb -->
			<a href={p('/works')} style="font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);display:inline-block;margin-bottom:24px;transition:color .2s" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--muted)'">{t.works.backLink}</a>

			<div class="vd-detailwrap">
				<!-- Image panel -->
				<div style="position:relative;background:#1a221c;min-height:clamp(280px,52vh,640px);overflow:hidden;display:flex;align-items:center;justify-content:center;border-radius:4px">
					{artwork.coverImage?.original ? (
						<img
							src={artwork.coverImage.medium ?? artwork.coverImage.original}
							alt={artwork.coverImage.alt ?? artwork.title}
							width={artwork.coverImage.width}
							height={artwork.coverImage.height}
							loading="eager"
							style="width:100%;height:100%;object-fit:contain;position:absolute;inset:0"
						/>
					) : (
						<div style="position:absolute;inset:0;background:radial-gradient(130% 120% at 30% 14%,#d9b25e 0%,#6b4f37 44%,#243029 100%)"></div>
					)}
					<span style="position:absolute;left:16px;top:14px;font-family:'Spline Sans Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.72)">{artwork.year}</span>
				</div>

				<!-- Detail panel -->
				<div style="padding:clamp(22px,2.6vw,40px) 0;display:flex;flex-direction:column;gap:0">
					<div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
						<span style={`display:inline-block;width:9px;height:9px;border-radius:50%;background:${availColor}`}></span>
						<span style={`font-family:'Spline Sans Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:${availColor}`}>{availLabel}</span>
					</div>

					<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(30px,4vw,44px);line-height:1.04;margin:0;color:var(--ink)">{artwork.title}</h1>
					<div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:20px;color:var(--bark);margin-top:4px">{artwork.year}</div>

					{artwork.description && (
						<p style="margin:18px 0 0;font-size:16px;line-height:1.7;color:#41463d">{artwork.description}</p>
					)}

					<div class="vd-meta" style="margin-top:24px">
						{techniqueName && (
							<div class="vd-meta-row">
								<span class="vd-meta-label">{t.artworkMeta.technique}</span>
								<span class="vd-meta-value">{techniqueName}</span>
							</div>
						)}
						{artwork.support && (
							<div class="vd-meta-row">
								<span class="vd-meta-label">{t.artworkMeta.support}</span>
								<span class="vd-meta-value">{artwork.support}</span>
							</div>
						)}
						{dimStr && (
							<div class="vd-meta-row">
								<span class="vd-meta-label">{t.artworkMeta.dimensions}</span>
								<span class="vd-meta-value">{dimStr}</span>
							</div>
						)}
						{seriesName && (
							<div class="vd-meta-row">
								<span class="vd-meta-label">{t.artworkMeta.series}</span>
								<span class="vd-meta-value" style="color:var(--verde)">{seriesName}</span>
							</div>
						)}
					</div>

					<div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:24px">
						<a href={p('/commissions')} class="vd-btn-primary" style="font-size:14.5px;padding:12px 22px">{t.works.requestInfo}</a>
					</div>
				</div>
			</div>

			<!-- Gallery -->
			{gallery.length > 0 && (
				<section style="margin-top:clamp(40px,5vw,64px)">
					<div class="vd-divider" style="margin-bottom:clamp(24px,3vw,40px)">
						<span class="vd-divider-line"></span>
						<span class="vd-divider-diamond"></span>
						<span class="vd-divider-line"></span>
					</div>
					<div class="vd-cards">
						{gallery.map((img) => (
							<figure style="margin:0;overflow:hidden;border-radius:3px;border:1px solid var(--line)">
								<img
									src={img.medium ?? img.thumb ?? img.original}
									alt={img.alt ?? ''}
									width={img.width}
									height={img.height}
									loading="lazy"
									style="width:100%;aspect-ratio:4/3;object-fit:cover"
								/>
								{img.caption && (
									<figcaption style="font-size:0.8rem;color:var(--muted);margin-top:0;padding:8px 12px;background:var(--parchment);font-family:'Spline Sans Mono',monospace;font-size:11px">{img.caption}</figcaption>
								)}
							</figure>
						))}
					</div>
				</section>
			)}
		</div>
	</section>
</BaseLayout>
