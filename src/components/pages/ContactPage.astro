---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommissionRequestForm from '@/components/CommissionRequestForm'
import { useTranslations } from '@/i18n/utils'

interface Props {
	locale: string
}

const { locale } = Astro.props
const t = useTranslations(locale)

const pageTitle = locale === 'it' ? 'Contattami — Valentina Damiano' : 'Contact — Valentina Damiano'
---

<BaseLayout title={pageTitle} lang={locale} description={t.meta.contactDescription}>
	<section class="vd-rise" style="padding:clamp(34px,5vw,64px) 0 clamp(50px,6vw,90px)">
		<div class="container">
			<div style="position:relative">
				<span style="position:absolute;left:-26px;top:-18px;width:70px;height:70px;border-radius:50%;background:conic-gradient(from 180deg,var(--rose),var(--syellow),var(--sblue),var(--rose));filter:blur(20px);opacity:.3;pointer-events:none"></span>

				<div class="vd-eyebrow">{t.commissions.eyebrow}</div>
				<h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(34px,5.5vw,62px);margin:10px 0 0;color:var(--ink)">{t.commissions.title}</h1>
				<p style="max-width:52ch;margin:14px 0 28px;font-size:16.5px;line-height:1.7;color:#52564c">{t.commissions.subtitle}</p>
			</div>

			<!-- Form -->
			<CommissionRequestForm
				client:visible
				labels={t.commissions}
			/>
		</div>
	</section>
</BaseLayout>
